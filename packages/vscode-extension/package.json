{
    "name": "jsoniq-vscode",
    "displayName": "JSONiq Language Support",
    "version": "1.4.0",
    "private": true,
    "description": "JSONiq language support for Visual Studio Code, powered by the JSONiq Language Server.",
    "categories": [
        "Programming Languages"
    ],
    "repository": {
        "url": "https://github.com/RumbleDB/jsoniq-lsp",
        "directory": "packages/vscode-extension"
    },
    "publisher": "RumbleDB",
    "main": "./dist/extension.js",
    "scripts": {
        "build": "pnpm run clean && pnpm run typecheck && rolldown -c",
        "build:prod": "pnpm run clean && pnpm run typecheck && rolldown -c  --environment BUILD:production",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "watch": "rolldown -c -w",
        "clean": "rm -rf dist",
        "lint": "oxlint",
        "lint:fix": "oxlint --fix",
        "fmt": "oxfmt",
        "fmt:check": "oxfmt --check"
    },
    "dependencies": {
        "jsoniq-language-server": "workspace:*",
        "vscode-languageclient": "^10.0.0"
    },
    "devDependencies": {
        "@types/node": "^25.9.3",
        "@types/vscode": "^1.120.0",
        "oxfmt": "^0.54.0",
        "oxlint": "^1.69.0",
        "rolldown": "1.1.0",
        "typescript": "^6.0.3"
    },
    "contributes": {
        "languages": [
            {
                "id": "jsoniq",
                "aliases": [
                    "JSONiq"
                ],
                "extensions": [
                    ".jq",
                    ".jsoniq"
                ],
                "configuration": "./language-configuration.json"
            },
            {
                "id": "xquery",
                "aliases": [
                    "XQuery"
                ],
                "extensions": [
                    ".xq",
                    ".xqy",
                    ".xquery"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "jsoniq",
                "scopeName": "source.jsoniq",
                "path": "./syntaxes/jsoniq.tmLanguage.json"
            },
            {
                "language": "xquery",
                "scopeName": "source.xquery",
                "path": "./syntaxes/xquery.tmLanguage.json"
            },
            {
                "scopeName": "source.jsoniq-notebook-injection",
                "path": "./syntaxes/jsoniq-notebook-injection.tmLanguage.json",
                "injectTo": [
                    "source.python"
                ],
                "embeddedLanguages": {
                    "meta.embedded.block.jsoniq": "jsoniq"
                }
            }
        ],
        "configurationDefaults": {
            "[jsoniq]": {
                "editor.wordBasedSuggestions": "off",
                "editor.suggest.showWords": false
            },
            "[xquery]": {
                "editor.wordBasedSuggestions": "off",
                "editor.suggest.showWords": false
            }
        },
        "configuration": {
            "title": "JSONiq Language Support Configuration",
            "properties": {
                "jsoniq.lsp.wrapper.enabled": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable enhanced LSP features powered by the RumbleDB Java wrapper (requires Java 17+ to be installed)."
                }
            }
        }
    },
    "activationEvents": [
        "onNotebook:jupyter-notebook"
    ],
    "icon": "assets/icon.png",
    "engines": {
        "vscode": "^1.120.0"
    }
}
