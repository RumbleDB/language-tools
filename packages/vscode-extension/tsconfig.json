{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "outDir": "dist",
        "rootDir": "src",
        "strict": true,
        "noUncheckedIndexedAccess": true,
        "exactOptionalPropertyTypes": true,
        "sourceMap": true,
        "skipLibCheck": true,
        "lib": ["ES2022"],
        "types": ["node", "vscode"]
    },
    "include": ["src"]
}
