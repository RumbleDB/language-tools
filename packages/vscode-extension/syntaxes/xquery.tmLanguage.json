{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "XQuery",
    "scopeName": "source.xquery",
    "patterns": [
        {
            "include": "#comments"
        },
        {
            "include": "#pragmas"
        },
        {
            "include": "#xml-comments"
        },
        {
            "include": "#cdata"
        },
        {
            "include": "#xml-pi"
        },
        {
            "include": "#string-constructors"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#entities"
        },
        {
            "include": "#numbers"
        },
        {
            "include": "#declarations"
        },
        {
            "include": "#annotations"
        },
        {
            "include": "#function-references"
        },
        {
            "include": "#function-calls"
        },
        {
            "include": "#variables"
        },
        {
            "include": "#braced-uri-names"
        },
        {
            "include": "#axes"
        },
        {
            "include": "#types"
        },
        {
            "include": "#keywords"
        },
        {
            "include": "#xml-elements"
        },
        {
            "include": "#operators"
        }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.block.xquery",
                    "begin": "\\(:",
                    "end": ":\\)",
                    "patterns": [
                        {
                            "include": "#comments"
                        }
                    ]
                }
            ]
        },
        "pragmas": {
            "patterns": [
                {
                    "name": "meta.pragma.xquery",
                    "begin": "\\(#",
                    "beginCaptures": {
                        "0": {
                            "name": "punctuation.definition.pragma.begin.xquery"
                        }
                    },
                    "end": "#\\)",
                    "endCaptures": {
                        "0": {
                            "name": "punctuation.definition.pragma.end.xquery"
                        }
                    },
                    "patterns": [
                        {
                            "include": "#strings"
                        },
                        {
                            "include": "#entities"
                        },
                        {
                            "include": "#braced-uri-names"
                        },
                        {
                            "name": "entity.name.tag.pragma.xquery",
                            "match": "(?:[A-Za-z_][A-Za-z0-9._-]*:)?[A-Za-z_][A-Za-z0-9._-]*"
                        }
                    ]
                }
            ]
        },
        "xml-comments": {
            "patterns": [
                {
                    "name": "comment.block.xml.xquery",
                    "begin": "<!--",
                    "end": "-->"
                }
            ]
        },
        "cdata": {
            "patterns": [
                {
                    "name": "string.unquoted.cdata.xml.xquery",
                    "begin": "<!\\[CDATA\\[",
                    "end": "\\]\\]>"
                }
            ]
        },
        "xml-pi": {
            "patterns": [
                {
                    "name": "meta.processing-instruction.xml.xquery",
                    "begin": "<\\?([A-Za-z_][A-Za-z0-9._-]*)",
                    "beginCaptures": {
                        "1": {
                            "name": "entity.name.tag.processing-instruction.xml.xquery"
                        }
                    },
                    "end": "\\?>",
                    "patterns": [
                        {
                            "include": "#strings"
                        },
                        {
                            "include": "#entities"
                        }
                    ]
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.xquery",
                    "begin": "\"",
                    "beginCaptures": {
                        "0": {
                            "name": "punctuation.definition.string.begin.xquery"
                        }
                    },
                    "end": "\"(?!\")",
                    "endCaptures": {
                        "0": {
                            "name": "punctuation.definition.string.end.xquery"
                        }
                    },
                    "patterns": [
                        {
                            "name": "constant.character.escape.quote.xquery",
                            "match": "\"\""
                        },
                        {
                            "name": "constant.character.escape.brace.xquery",
                            "match": "\\{\\{|\\}\\}"
                        },
                        {
                            "include": "#entities"
                        },
                        {
                            "include": "#enclosed-expression"
                        }
                    ]
                },
                {
                    "name": "string.quoted.single.xquery",
                    "begin": "'",
                    "beginCaptures": {
                        "0": {
                            "name": "punctuation.definition.string.begin.xquery"
                        }
                    },
                    "end": "'(?!')",
                    "endCaptures": {
                        "0": {
                            "name": "punctuation.definition.string.end.xquery"
                        }
                    },
                    "patterns": [
                        {
                            "name": "constant.character.escape.apostrophe.xquery",
                            "match": "''"
                        },
                        {
                            "name": "constant.character.escape.brace.xquery",
                            "match": "\\{\\{|\\}\\}"
                        },
                        {
                            "include": "#entities"
                        },
                        {
                            "include": "#enclosed-expression"
                        }
                    ]
                }
            ]
        },
        "string-constructors": {
            "patterns": [
                {
                    "name": "string.interpolated.backtick.xquery",
                    "begin": "``\\[",
                    "beginCaptures": {
                        "0": {
                            "name": "punctuation.definition.string.begin.xquery"
                        }
                    },
                    "end": "\\]``",
                    "endCaptures": {
                        "0": {
                            "name": "punctuation.definition.string.end.xquery"
                        }
                    },
                    "patterns": [
                        {
                            "begin": "`\\{",
                            "beginCaptures": {
                                "0": {
                                    "name": "punctuation.section.embedded.begin.xquery"
                                }
                            },
                            "end": "\\}`",
                            "endCaptures": {
                                "0": {
                                    "name": "punctuation.section.embedded.end.xquery"
                                }
                            },
                            "name": "meta.embedded.expression.xquery",
                            "patterns": [
                                {
                                    "include": "$self"
                                }
                            ]
                        }
                    ]
                }
            ]
        },
        "entities": {
            "patterns": [
                {
                    "name": "constant.character.entity.predefined.xml.xquery",
                    "match": "&(?:lt|gt|amp|quot|apos);"
                },
                {
                    "name": "constant.character.entity.numeric.xml.xquery",
                    "match": "&#(?:[0-9]+|x[0-9A-Fa-f]+);"
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.double.xquery",
                    "match": "(?<![\\w.-])(?:\\.[0-9]+|[0-9]+(?:\\.[0-9]*)?)[eE][+-]?[0-9]+(?![\\w.-])"
                },
                {
                    "name": "constant.numeric.decimal.xquery",
                    "match": "(?<![\\w.-])(?:\\.[0-9]+|[0-9]+\\.[0-9]*)(?![\\w.-])"
                },
                {
                    "name": "constant.numeric.integer.xquery",
                    "match": "(?<![\\w.-])[0-9]+(?![\\w.-])"
                }
            ]
        },
        "declarations": {
            "patterns": [
                {
                    "name": "meta.declaration.function.xquery",
                    "match": "\\b(declare)\\b\\s+(?:(%)(?:Q\\{[^{}&]*\\})?(?:[A-Za-z_][A-Za-z0-9._-]*:)?[A-Za-z_][A-Za-z0-9._-]*(?:\\s*\\([^)]*\\))?\\s+|\\b(updating)\\b\\s+)*\\b(function)\\b\\s+((?:Q\\{[^{}&]*\\})?(?:[A-Za-z_][A-Za-z0-9._-]*:)?[A-Za-z_][A-Za-z0-9._-]*)",
                    "captures": {
                        "1": {
                            "name": "keyword.control.declare.xquery"
                        },
                        "2": {
                            "name": "punctuation.definition.annotation.xquery"
                        },
                        "3": {
                            "name": "storage.modifier.updating.xquery"
                        },
                        "4": {
                            "name": "keyword.control.function.xquery"
                        },
                        "5": {
                            "name": "entity.name.function.xquery"
                        }
                    }
                },
                {
                    "name": "meta.declaration.variable.xquery",
                    "match": "\\b(declare)\\b\\s+(?:(%)(?:Q\\{[^{}&]*\\})?(?:[A-Za-z_][A-Za-z0-9._-]*:)?[A-Za-z_][A-Za-z0-9._-]*(?:\\s*\\([^)]*\\))?\\s+|\\b(updating)\\b\\s+)*\\b(variable)\\b\\s+(\\$)(?:(Q\\{[^{}&]*\\})?([A-Za-z_][A-Za-z0-9._-]*))",
                    "captures": {
                        "1": {
                            "name": "keyword.control.declare.xquery"
                        },
                        "2": {
                            "name": "punctuation.definition.annotation.xquery"
                        },
                        "3": {
                            "name": "storage.modifier.updating.xquery"
                        },
                        "4": {
                            "name": "keyword.control.variable.xquery"
                        },
                        "5": {
                            "name": "punctuation.definition.variable.xquery"
                        },
                        "6": {
                            "name": "support.type.uri.xquery"
                        },
                        "7": {
                            "name": "variable.other.readwrite.xquery"
                        }
                    }
                },
                {
                    "name": "meta.declaration.namespace.xquery",
                    "match": "\\b(declare)\\b\\s+(namespace)\\b\\s+([A-Za-z_][A-Za-z0-9._-]*)",
                    "captures": {
                        "1": {
                            "name": "keyword.control.declare.xquery"
                        },
                        "2": {
                            "name": "keyword.control.namespace.xquery"
                        },
                        "3": {
                            "name": "entity.name.namespace.xquery"
                        }
                    }
                },
                {
                    "name": "meta.declaration.default-namespace.xquery",
                    "match": "\\b(declare)\\b\\s+(default)\\b\\s+(element|function)\\b\\s+(namespace)\\b",
                    "captures": {
                        "1": {
                            "name": "keyword.control.declare.xquery"
                        },
                        "2": {
                            "name": "keyword.control.default.xquery"
                        },
                        "3": {
                            "name": "storage.type.namespace-kind.xquery"
                        },
                        "4": {
                            "name": "keyword.control.namespace.xquery"
                        }
                    }
                },
                {
                    "name": "meta.module-declaration.xquery",
                    "match": "\\b(module)\\b\\s+(namespace)\\b\\s+([A-Za-z_][A-Za-z0-9._-]*)",
                    "captures": {
                        "1": {
                            "name": "keyword.control.module.xquery"
                        },
                        "2": {
                            "name": "keyword.control.namespace.xquery"
                        },
                        "3": {
                            "name": "entity.name.namespace.xquery"
                        }
                    }
                },
                {
                    "name": "meta.version-declaration.xquery",
                    "match": "\\b(xquery)\\b\\s+(version|encoding)\\b",
                    "captures": {
                        "1": {
                            "name": "keyword.control.xquery.xquery"
                        },
                        "2": {
                            "name": "keyword.control.version.xquery"
                        }
                    }
                }
            ]
        },
        "annotations": {
            "patterns": [
                {
                    "name": "storage.modifier.updating.xquery",
                    "match": "\\bupdating\\b"
                },
                {
                    "name": "meta.annotation.xquery",
                    "match": "(%)(?:((?:Q\\{[^{}&]*\\})?)([A-Za-z_][A-Za-z0-9._-]*)(:))?([A-Za-z_][A-Za-z0-9._-]*)",
                    "captures": {
                        "1": {
                            "name": "punctuation.definition.annotation.xquery"
                        },
                        "2": {
                            "name": "support.type.uri.xquery"
                        },
                        "3": {
                            "name": "entity.name.namespace.xquery"
                        },
                        "4": {
                            "name": "punctuation.separator.namespace.xquery"
                        },
                        "5": {
                            "name": "entity.name.tag.annotation.xquery"
                        }
                    }
                }
            ]
        },
        "function-references": {
            "patterns": [
                {
                    "name": "meta.function-reference.xquery",
                    "match": "((?:Q\\{[^{}&]*\\})?(?:[A-Za-z_][A-Za-z0-9._-]*:)?[A-Za-z_][A-Za-z0-9._-]*)(#)([0-9]+)",
                    "captures": {
                        "1": {
                            "name": "entity.name.function.xquery"
                        },
                        "2": {
                            "name": "punctuation.separator.hash.xquery"
                        },
                        "3": {
                            "name": "constant.numeric.integer.arity.xquery"
                        }
                    }
                }
            ]
        },
        "function-calls": {
            "patterns": [
                {
                    "name": "meta.function-call.xquery",
                    "match": "\\b(?!(?:array|attribute|binary|comment|document|document-node|element|empty-sequence|function|if|item|map|namespace|namespace-node|node|processing-instruction|schema-attribute|schema-element|switch|text|try|typeswitch)\\s*\\()((?:[A-Za-z_][A-Za-z0-9._-]*:)?[A-Za-z_][A-Za-z0-9._-]*)(?=\\s*\\()",
                    "captures": {
                        "1": {
                            "name": "entity.name.function.xquery"
                        }
                    }
                },
                {
                    "name": "meta.function-call.xquery",
                    "match": "(Q\\{[^{}&]*\\}[A-Za-z_][A-Za-z0-9._-]*)(?=\\s*\\()",
                    "captures": {
                        "1": {
                            "name": "entity.name.function.xquery"
                        }
                    }
                }
            ]
        },
        "variables": {
            "patterns": [
                {
                    "name": "variable.other.xquery",
                    "match": "(\\$)(Q\\{[^{}&]*\\})?((?:[A-Za-z_][A-Za-z0-9._-]*:)?[A-Za-z_][A-Za-z0-9._-]*)",
                    "captures": {
                        "1": {
                            "name": "punctuation.definition.variable.xquery"
                        },
                        "2": {
                            "name": "support.type.uri.xquery"
                        },
                        "3": {
                            "name": "variable.other.readwrite.xquery"
                        }
                    }
                }
            ]
        },
        "braced-uri-names": {
            "patterns": [
                {
                    "name": "entity.name.qualified.uri.xquery",
                    "match": "(Q\\{[^{}&]*\\})([A-Za-z_][A-Za-z0-9._-]*|\\*)",
                    "captures": {
                        "1": {
                            "name": "support.type.uri.xquery"
                        },
                        "2": {
                            "name": "entity.name.tag.localname.xquery"
                        }
                    }
                }
            ]
        },
        "axes": {
            "patterns": [
                {
                    "name": "keyword.operator.axis.xquery",
                    "match": "\\b(?:ancestor|ancestor-or-self|attribute|child|descendant|descendant-or-self|following|following-sibling|parent|preceding|preceding-sibling|self)::"
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "name": "storage.type.kind-test.xquery",
                    "match": "\\b(?:array-node|attribute|binary|boolean-node|comment|document-node|element|empty-sequence|function|item|map|namespace-node|node|null-node|number-node|object-node|processing-instruction|schema-attribute|schema-element|text)\\b(?=\\s*\\()"
                },
                {
                    "name": "storage.type.constructor.xquery",
                    "match": "\\b(?:array|attribute|comment|document|element|namespace|processing-instruction|text)\\b(?=\\s*\\{)"
                },
                {
                    "name": "storage.type.primitive.xquery",
                    "match": "\\b(?:xs:)?(?:anyAtomicType|anySimpleType|anyURI|base64Binary|boolean|byte|date|dateTime|dayTimeDuration|decimal|double|duration|ENTITY|float|gDay|gMonth|gMonthDay|gYear|gYearMonth|hexBinary|ID|IDREF|int|integer|language|long|Name|NCName|negativeInteger|NMTOKEN|nonNegativeInteger|nonPositiveInteger|normalizedString|NOTATION|positiveInteger|QName|short|string|time|token|unsignedByte|unsignedInt|unsignedLong|unsignedShort|untyped|untypedAtomic|yearMonthDuration)\\b"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.xquery",
                    "match": "\\b(?:allowing|as|at|break|case|catch|context|continue|count|declare|default|else|every|exit|external|for|group|if|import|in|let|loop|module|namespace|only|return|returning|satisfies|schema|some|stable|start|switch|then|try|typeswitch|validate|variable|version|when|where|while|window|xquery)\\b"
                },
                {
                    "name": "keyword.control.flwor.xquery",
                    "match": "\\b(?:ascending|by|collation|descending|empty|end|greatest|least|next|order|previous|sliding|tumbling)\\b"
                },
                {
                    "name": "keyword.control.import.xquery",
                    "match": "\\b(?:base-uri|boundary-space|construction|copy-namespaces|decimal-format|encoding|inherit|lax|no-inherit|no-preserve|option|ordering|ordered|preserve|strict|strip|unordered)\\b"
                },
                {
                    "name": "keyword.control.update.xquery",
                    "match": "\\b(?:after|append|before|collection|copy|create|delete|delta-file|edit|first|from|iceberg-table|insert|into|json|last|modify|position|rename|replace|table|truncate|update|value|with)\\b"
                },
                {
                    "name": "keyword.operator.word.xquery",
                    "match": "\\b(?:and|cast|castable|div|eq|except|ge|gt|idiv|instance|intersect|is|le|lt|mod|ne|of|or|statically|to|treat|union)\\b"
                },
                {
                    "name": "support.constant.decimal-format.xquery",
                    "match": "\\b(?:NaN|decimal-separator|digit|exponent-separator|grouping-separator|infinity|minus-sign|pattern-separator|percent|per-mille|zero-digit)\\b"
                }
            ]
        },
        "xml-elements": {
            "patterns": [
                {
                    "name": "meta.tag.xml.xquery",
                    "begin": "(<)(?![!?/])((?:[A-Za-z_][A-Za-z0-9._-]*:)?[A-Za-z_][A-Za-z0-9._-]*)",
                    "beginCaptures": {
                        "1": {
                            "name": "punctuation.definition.tag.begin.xml.xquery"
                        },
                        "2": {
                            "name": "entity.name.tag.xml.xquery"
                        }
                    },
                    "end": "(/?>)",
                    "endCaptures": {
                        "1": {
                            "name": "punctuation.definition.tag.end.xml.xquery"
                        }
                    },
                    "patterns": [
                        {
                            "include": "#comments"
                        },
                        {
                            "include": "#strings"
                        },
                        {
                            "include": "#entities"
                        },
                        {
                            "include": "#enclosed-expression"
                        },
                        {
                            "name": "entity.other.attribute-name.xml.xquery",
                            "match": "(?:[A-Za-z_][A-Za-z0-9._-]*:)?[A-Za-z_][A-Za-z0-9._-]*"
                        },
                        {
                            "name": "keyword.operator.assignment.xml.xquery",
                            "match": "="
                        }
                    ]
                },
                {
                    "name": "meta.tag.xml.xquery",
                    "begin": "(</)((?:[A-Za-z_][A-Za-z0-9._-]*:)?[A-Za-z_][A-Za-z0-9._-]*)",
                    "beginCaptures": {
                        "1": {
                            "name": "punctuation.definition.tag.begin.xml.xquery"
                        },
                        "2": {
                            "name": "entity.name.tag.xml.xquery"
                        }
                    },
                    "end": "(>)",
                    "endCaptures": {
                        "1": {
                            "name": "punctuation.definition.tag.end.xml.xquery"
                        }
                    }
                }
            ]
        },
        "enclosed-expression": {
            "patterns": [
                {
                    "name": "meta.embedded.expression.xquery",
                    "begin": "(?<!\\{)\\{(?!\\{)",
                    "beginCaptures": {
                        "0": {
                            "name": "punctuation.section.embedded.begin.xquery"
                        }
                    },
                    "end": "(?<!\\})\\}(?!\\})",
                    "endCaptures": {
                        "0": {
                            "name": "punctuation.section.embedded.end.xquery"
                        }
                    },
                    "patterns": [
                        {
                            "include": "$self"
                        }
                    ]
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.arrow.xquery",
                    "match": "=>"
                },
                {
                    "name": "keyword.operator.comparison.node.xquery",
                    "match": "<<|>>"
                },
                {
                    "name": "keyword.operator.range.xquery",
                    "match": "\\.\\."
                },
                {
                    "name": "keyword.operator.assignment.xquery",
                    "match": ":="
                },
                {
                    "name": "keyword.operator.comparison.xquery",
                    "match": "!=|<=|>=|=|<|>"
                },
                {
                    "name": "keyword.operator.arithmetic.xquery",
                    "match": "\\|\\||//|[+\\-*/|!~\\\\]"
                },
                {
                    "name": "punctuation.definition.variable.xquery",
                    "match": "\\$"
                },
                {
                    "name": "punctuation.definition.lookup.xquery",
                    "match": "\\?"
                },
                {
                    "name": "punctuation.separator.xquery",
                    "match": "[,;:]"
                },
                {
                    "name": "punctuation.bracket.xquery",
                    "match": "[(){}\\[\\]]"
                }
            ]
        }
    }
}
