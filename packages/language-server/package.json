{
    "name": "jsoniq-language-server",
    "version": "2.7.0",
    "private": false,
    "license": "Apache-2.0",
    "repository": {
        "url": "https://github.com/RumbleDB/language-tools",
        "directory": "packages/language-server"
    },
    "files": [
        "dist",
        "assets"
    ],
    "type": "module",
    "exports": {
        ".": "./dist/main.mjs",
        "./notifications": "./dist/notifications/index.mjs",
        "./bundled": "./dist/bundled/main.mjs"
    },
    "scripts": {
        "generate:jsoniq-grammar": "antlr-ng -Dlanguage=TypeScript --generate-visitor true --output-directory src/parser/adapters/jsoniq/grammar src/parser/adapters/jsoniq/grammar/JsoniqLexer.g4 src/parser/adapters/jsoniq/grammar/JsoniqParser.g4",
        "generate:xquery-grammar": "antlr-ng -Dlanguage=TypeScript --generate-visitor true --output-directory src/parser/adapters/xquery/grammar src/parser/adapters/xquery/grammar/XQueryLexer.g4 src/parser/adapters/xquery/grammar/XQueryParser.g4",
        "generate:grammar": "pnpm run generate:jsoniq-grammar && pnpm run generate:xquery-grammar",
        "generate:w3-docs": "node scripts/parse-w3-function-docs.ts",
        "compile:function-docs": "node scripts/compile-function-docs.ts",
        "compile:builtins": "tsx scripts/dump-builtin.ts",
        "missing-function-docs": "tsx scripts/list-missing-function-docs.ts",
        "typecheck": "tsc --noEmit -p tsconfig.json",
        "build:assets": "pnpm run compile:function-docs && pnpm run compile:builtins",
        "build": "pnpm run build:assets && pnpm run typecheck && tsdown",
        "build:prod": "pnpm run build --no-sourcemap --minify",
        "watch": "tsc -w -p tsconfig.json",
        "start": "node ./dist/main.mjs",
        "test": "vitest run tests",
        "clean": "rm -rf dist",
        "ensure-wrapper": "node ./dist/wrapper/executable/ensure-wrapper.mjs",
        "lint": "oxlint",
        "lint:fix": "oxlint --fix",
        "fmt": "oxfmt",
        "fmt:check": "oxfmt --check"
    },
    "dependencies": {
        "antlr-ng": "^1.0.10",
        "antlr4-c3": "^3.4.4",
        "antlr4ng": "^3.0.16",
        "vscode-languageserver": "^10.0.0",
        "vscode-languageserver-textdocument": "^1.0.12"
    },
    "devDependencies": {
        "@types/node": "^26.0.0",
        "fast-xml-parser": "^5.9.3",
        "gray-matter": "^4.0.3",
        "oxfmt": "^0.55.0",
        "oxlint": "^1.70.0",
        "tsc-alias": "^1.8.17",
        "tsdown": "^0.22.3",
        "tsx": "^4.22.4",
        "typescript": "^6.0.3",
        "vitest": "^4.1.9"
    }
}
