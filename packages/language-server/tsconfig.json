{
    "compilerOptions": {
        "target": "es2025",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "outDir": "dist",
        "rootDir": "src",
        "strict": true,
        "noUncheckedIndexedAccess": true,
        "exactOptionalPropertyTypes": true,
        "declaration": true,
        "sourceMap": true,
        "skipLibCheck": true,
        "paths": {
            "server/*": ["./src/*"]
        },
        "types": ["node"]
    },
    "include": ["src"]
}
