{
    "name": "language-tools-workspace",
    "private": true,
    "license": "Apache-2.0",
    "scripts": {
        "build": "run-s build:core build:client",
        "build:prod": "pnpm run clean && run-s build:core:prod build:client",
        "changeset": "changeset",
        "release:status": "changeset status --verbose",
        "release:version": "changeset version",
        "release:publish": "node scripts/release/publish-prod.mts",
        "release:publish-dev": "node scripts/release/publish-dev.mts",
        "build:core": "run-s build:wrapper build:server",
        "build:core:prod": "run-s build:wrapper:prod build:server:prod",
        "build:wrapper": "pnpm --filter rumble-lsp-wrapper run build",
        "build:wrapper:prod": "pnpm --filter rumble-lsp-wrapper run build:prod",
        "build:server": "pnpm --filter jsoniq-language-server run build",
        "build:server:prod": "pnpm --filter jsoniq-language-server run build:prod",
        "build:client": "pnpm --filter jsoniq-vscode run build",
        "generate:grammar": "pnpm --filter jsoniq-language-server run generate:grammar",
        "start": "pnpm --filter jsoniq-language-server run start",
        "test": "pnpm --filter jsoniq-language-server run test",
        "clean": "pnpm --filter jsoniq-language-server run clean && pnpm --filter rumble-lsp-wrapper run clean && pnpm --filter jsoniq-vscode run clean",
        "lint": "oxlint",
        "lint:fix": "oxlint --fix",
        "fmt": "oxfmt",
        "fmt:check": "oxfmt --check",
        "prepare": "husky || true"
    },
    "devDependencies": {
        "@changesets/changelog-github": "^0.7.0",
        "@changesets/cli": "^2.31.0",
        "@octokit/rest": "^22.0.1",
        "husky": "^9.1.7",
        "lint-staged": "^17.0.7",
        "npm-run-all2": "^9.0.2",
        "oxfmt": "^0.55.0",
        "oxlint": "^1.70.0"
    },
    "lint-staged": {
        "*.{js,jsx,ts,tsx,mjs,cjs}": [
            "pnpm run lint --"
        ],
        "*": [
            "pnpm run fmt:check --no-error-on-unmatched-pattern --"
        ]
    },
    "packageManager": "pnpm@11.0.5"
}
